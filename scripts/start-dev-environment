#!/usr/bin/env bash
# Build and start a local MosaicFS dev environment (agent + web_ui) backed
# by a containerised CouchDB. Works on macOS (Apple `container` CLI) and
# Linux (podman / docker). Re-running is idempotent.
#
# Layout:
#   dev-config/mosaicfs.toml   generated config
#   dev-data/                  watch_paths target, seeded with README.md
#   dev-run/mosaicfs.log       binary stdout+stderr
#   dev-run/mosaicfs.pid       binary PID
#   dev-run/agent-state/       agent state_dir
#   dev-run/server-data/       web_ui data_dir
#
# Stop with scripts/stop-dev-environment.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

DEV_CONFIG="$REPO_ROOT/dev-config"
DEV_DATA="$REPO_ROOT/dev-data"
DEV_RUN="$REPO_ROOT/dev-run"
CONFIG_FILE="$DEV_CONFIG/mosaicfs.toml"
LOG_FILE="$DEV_RUN/mosaicfs.log"
PID_FILE="$DEV_RUN/mosaicfs.pid"

DB_CONTAINER="mosaicfs-db"
DB_PORT=5984
DB_HOST="127.0.0.1"   # overridden to container IP for apple runtime (no localhost port-forward)
DB_USER=admin
DB_PASSWORD=changeme
WEB_UI_PORT=8443

log() { printf '==> %s\n' "$*"; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

# ── 0. Detect container runtime ─────────────────────────────────────────────
# On macOS prefer Apple's `container` CLI (matches the existing Makefile flow
# and DEPLOYMENT.md); fall back to podman/docker. On Linux prefer podman.
case "$(uname)" in
    Darwin)
        if [[ -x /usr/local/bin/container ]]; then
            CONTAINER=/usr/local/bin/container
            RUNTIME=apple
        elif command -v podman >/dev/null 2>&1; then
            CONTAINER=$(command -v podman); RUNTIME=podman
        elif command -v docker >/dev/null 2>&1; then
            CONTAINER=$(command -v docker); RUNTIME=docker
        else
            die "no container runtime found (need Apple container, podman, or docker)"
        fi
        ;;
    Linux)
        if command -v podman >/dev/null 2>&1; then
            CONTAINER=$(command -v podman); RUNTIME=podman
        elif command -v docker >/dev/null 2>&1; then
            CONTAINER=$(command -v docker); RUNTIME=docker
        else
            die "no container runtime found (need podman or docker)"
        fi
        ;;
    *) die "unsupported OS: $(uname)" ;;
esac

# Apple `container` doesn't resolve docker.io transparently for Fauxton/v3 —
# mirror the Makefile and build a tiny local image from Dockerfile.mosaicfs-db.
# podman/docker can pull `docker.io/couchdb:3` directly.
if [[ "$RUNTIME" == "apple" ]]; then
    DB_IMAGE="mosaicfs-db:latest"
else
    DB_IMAGE="docker.io/couchdb:3"
fi

log "Container runtime: $CONTAINER ($RUNTIME), image $DB_IMAGE"

# ── 1. Build all Rust crates ────────────────────────────────────────────────
log "Building Rust workspace (cargo build --workspace)"
cargo build --workspace

BINARY="$REPO_ROOT/target/debug/mosaicfs"
[[ -x "$BINARY" ]] || die "$BINARY not found after build"

# ── 2. Start CouchDB container ──────────────────────────────────────────────
# Fastest-first strategy:
#   1. DB already responding  → nothing to do.
#   2. Container stopped      → start it (no rebuild).
#   3. Image exists           → run a new container (no rebuild).
#   4. Image absent           → build it, then run.
#
# Apple's container CLI does not forward ports to 127.0.0.1 — each container
# gets its own IP on a bridged VM network. We resolve that IP from inspect and
# store it in DB_HOST; podman/docker use the default 127.0.0.1.

if [[ "$RUNTIME" == "apple" ]]; then
    # inspect returns [] (exit 0) when container is absent.
    _inspect=$("$CONTAINER" inspect "$DB_CONTAINER" 2>/dev/null)
    _state=$(echo "$_inspect" | python3 -c \
        "import json,sys; c=json.load(sys.stdin); print(c[0]['status'] if c else 'absent')" \
        2>/dev/null || echo absent)

    if [[ "$_state" == "running" ]]; then
        DB_HOST=$(echo "$_inspect" | python3 -c \
            "import json,sys; c=json.load(sys.stdin); \
             print(c[0]['networks'][0]['ipv4Address'].split('/')[0])" 2>/dev/null) || true
        log "CouchDB container already running at ${DB_HOST}:${DB_PORT}"
    else
        # Build image only if it doesn't already exist.
        if ! "$CONTAINER" image list 2>/dev/null \
                | awk 'NR>1 {print $1":"$2}' | grep -qx "$DB_IMAGE"; then
            log "Building $DB_IMAGE from Dockerfile.mosaicfs-db"
            "$CONTAINER" build -f Dockerfile.mosaicfs-db -t "$DB_IMAGE" .
        fi
        if [[ "$_state" == "absent" ]]; then
            log "Creating CouchDB container"
            "$CONTAINER" run -d --name "$DB_CONTAINER" \
                -e "COUCHDB_USER=${DB_USER}" \
                -e "COUCHDB_PASSWORD=${DB_PASSWORD}" \
                -v mosaicfs-couchdb-data:/opt/couchdb/data \
                "$DB_IMAGE" >/dev/null
        else
            log "CouchDB container stopped; starting it"
            "$CONTAINER" start "$DB_CONTAINER" >/dev/null \
                || die "failed to start $DB_CONTAINER"
        fi
        DB_HOST=$("$CONTAINER" inspect "$DB_CONTAINER" 2>/dev/null \
            | python3 -c \
                "import json,sys; c=json.load(sys.stdin); \
                 print(c[0]['networks'][0]['ipv4Address'].split('/')[0])" \
            2>/dev/null) || true
        [[ -n "$DB_HOST" ]] || die "could not determine IP for $DB_CONTAINER"
        log "CouchDB container IP: $DB_HOST"
    fi
else
    # podman / docker: ports forwarded to 127.0.0.1.
    if curl -fsS -o /dev/null "http://127.0.0.1:${DB_PORT}/" 2>/dev/null; then
        log "CouchDB already running — skipping"
    else
        run_out=$("$CONTAINER" run -d --name "$DB_CONTAINER" \
            -p "127.0.0.1:${DB_PORT}:5984" \
            -e "COUCHDB_USER=${DB_USER}" \
            -e "COUCHDB_PASSWORD=${DB_PASSWORD}" \
            -v mosaicfs-couchdb-data:/opt/couchdb/data \
            "$DB_IMAGE" 2>&1) && run_rc=0 || run_rc=$?
        if [[ "$run_rc" -eq 0 ]]; then
            log "Started fresh CouchDB container"
        elif echo "$run_out" | grep -qiE 'already (in use|exists)|exists'; then
            log "CouchDB container exists; starting it"
            "$CONTAINER" start "$DB_CONTAINER" >/dev/null 2>&1 \
                || die "failed to start existing $DB_CONTAINER"
        else
            die "failed to create CouchDB container: $run_out"
        fi
    fi
fi

printf '    waiting for CouchDB on %s:%s' "$DB_HOST" "$DB_PORT"
for _ in $(seq 1 60); do
    if curl -fsS -o /dev/null "http://${DB_HOST}:${DB_PORT}/" 2>/dev/null; then
        printf ' ready.\n'; break
    fi
    printf '.'; sleep 1
done
curl -fsS -o /dev/null "http://${DB_HOST}:${DB_PORT}/" 2>/dev/null \
    || die "CouchDB did not become ready on ${DB_HOST}:${DB_PORT} within 60s"

# ── 2.5 / 3. Create dev-data and generate the config ────────────────────────
mkdir -p "$DEV_CONFIG" "$DEV_DATA" "$DEV_RUN" \
         "$DEV_RUN/agent-state" "$DEV_RUN/server-data"

if [[ ! -e "$DEV_DATA/README.md" ]]; then
    log "Seeding $DEV_DATA/README.md"
    printf 'Hello world\n' > "$DEV_DATA/README.md"
fi

log "Writing $CONFIG_FILE (agent + web_ui, watch_paths=$DEV_DATA)"
cat > "$CONFIG_FILE" <<EOF
# MosaicFS dev config — generated by scripts/start-dev-environment.
# Do not edit by hand; re-run the script to regenerate.

[node]

[features]
agent  = true
vfs    = false
web_ui = true

[agent]
watch_paths    = ["$DEV_DATA"]
excluded_paths = []
state_dir      = "$DEV_RUN/agent-state"

[couchdb]
url      = "http://${DB_HOST}:${DB_PORT}"
user     = "${DB_USER}"
password = "${DB_PASSWORD}"

[web_ui]
listen         = "127.0.0.1:${WEB_UI_PORT}"
data_dir       = "$DEV_RUN/server-data"
insecure_http  = true
developer_mode = true
EOF

# ── 4. Start the mosaicfs binary in the background ──────────────────────────
if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    log "mosaicfs already running (pid $(cat "$PID_FILE")); leaving it alone"
else
    log "Starting mosaicfs (logs: $LOG_FILE)"
    nohup "$BINARY" --config "$CONFIG_FILE" >"$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    disown || true
    sleep 1
    if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        die "mosaicfs exited immediately — check $LOG_FILE"
    fi
fi

# Wait for the HTTP listener to bind — the PID being alive only means the
# binary didn't crash on startup, not that it's accepting connections.
# /api/system/bootstrap-status is the only unauthenticated JSON endpoint;
# /api/health requires a JWT so it can't be used as a readiness probe.
READY_URL="http://127.0.0.1:${WEB_UI_PORT}/api/system/bootstrap-status"
printf '    waiting for web_ui on 127.0.0.1:%s' "$WEB_UI_PORT"
for _ in $(seq 1 60); do
    if curl -fsS -o /dev/null "$READY_URL" 2>/dev/null; then
        printf ' ready.\n'; break
    fi
    if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        printf '\n'; die "mosaicfs exited during startup — check $LOG_FILE"
    fi
    printf '.'; sleep 1
done
curl -fsS -o /dev/null "$READY_URL" 2>/dev/null \
    || die "web_ui did not become ready on 127.0.0.1:${WEB_UI_PORT} within 60s — check $LOG_FILE"

# ── 5. Confirm dev-data is registered as an agent filesystem ────────────────
# The agent reads watch_paths from the config on startup and crawls them;
# there is no separate runtime registration step. Log the registration for
# clarity.
log "Registered agent filesystem: $DEV_DATA (via [agent].watch_paths)"

cat <<EOF

Dev environment up.

  UI           http://127.0.0.1:${WEB_UI_PORT}/ui
  CouchDB      http://${DB_HOST}:${DB_PORT}/_utils  (${DB_USER} / ${DB_PASSWORD})
  Config       $CONFIG_FILE
  Log file     $LOG_FILE
  PID file     $PID_FILE

On first run, grab the bootstrap token:
  grep -i bootstrap "$LOG_FILE"

Tear down with: scripts/stop-dev-environment
EOF
